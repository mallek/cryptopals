root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Project/config files use 2-space indent
[*.{csproj,props,targets,slnx,json,yml,yaml}]
indent_size = 2

# Trailing whitespace is meaningful in markdown (forced line breaks)
[*.md]
trim_trailing_whitespace = false
